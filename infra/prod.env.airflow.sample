# Add these values to prod.env for the Airflow services.

# Airflow metadata database. Create this database/user in Postgres before
# starting the Airflow services.
AIRFLOW_DB_NAME=airflow_metadata
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me
AIRFLOW_DB_HOST=db
AIRFLOW_DB_PORT=5432

# Generate fresh production values; do not reuse local airflow.cfg values.
# Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# API/JWT secrets:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__CORE__FERNET_KEY=change-me
AIRFLOW__API__SECRET_KEY=change-me
AIRFLOW__API_AUTH__JWT_SECRET=change-me
